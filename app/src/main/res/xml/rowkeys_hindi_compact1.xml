<merge xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_au" />
    <!-- U+0914: "औ" DEVANAGARI LETTER AU
         U+0967: "१" DEVANAGARI DIGIT ONE -->
    <Key
        app:keySpec="&#x0914;"
        app:keyStyle="moreKeysDevanagariVowelSignAu"
        app:keyHintLabel="1"
        app:additionalMoreKeys="&#x0967;,1" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_ai" />
    <!-- U+0910: "ऐ" DEVANAGARI LETTER AI
         U+0968: "२" DEVANAGARI DIGIT TWO -->
    <Key
        app:keySpec="&#x0910;"
        app:keyStyle="moreKeysDevanagariVowelSignAi"
        app:keyHintLabel="2"
        app:additionalMoreKeys="&#x0968;,2" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_aa" />
    <!-- U+0906: "आ" DEVANAGARI LETTER AA
         U+0969: "३" DEVANAGARI DIGIT THREE -->
    <Key
        app:keySpec="&#x0906;"
        app:keyStyle="moreKeysDevanagariVowelSignAa"
        app:keyHintLabel="3"
        app:additionalMoreKeys="&#x0969;,3" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_ii" />
    <!-- U+0908: "ई" DEVANAGARI LETTER II
         U+096A: "४" DEVANAGARI DIGIT FOUR -->
    <Key
        app:keySpec="&#x0908;"
        app:keyStyle="moreKeysDevanagariVowelSignIi"
        app:keyHintLabel="4"
        app:additionalMoreKeys="&#x096A;,4" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_uu" />
    <!-- U+090A: "ऊ" DEVANAGARI LETTER UU
         U+096B: "५" DEVANAGARI DIGIT FIVE -->
    <Key
        app:keySpec="&#x090A;"
        app:keyStyle="moreKeysDevanagariVowelSignUu"
        app:keyHintLabel="5"
        app:additionalMoreKeys="&#x096B;,5" />
    <!-- U+092C: "ब" DEVANAGARI LETTER BA
         U+092D: "भ" DEVANAGARI LETTER BHA
         U+096C: "६" DEVANAGARI DIGIT SIX -->
    <Key
        app:keySpec="&#x092C;"
        app:moreKeys="&#x092D;,%"
        app:keyHintLabel="6"
        app:additionalMoreKeys="&#x096C;,6" />
    <!-- U+0939: "ह" DEVANAGARI LETTER HA
         U+096D: "७" DEVANAGARI DIGIT SEVEN -->
    <Key
        app:keySpec="&#x0939;"
        app:keyHintLabel="7"
        app:additionalMoreKeys="&#x096D;,7" />
    <!-- U+0917: "ग" DEVANAGARI LETTER GA
         U+0918: "घ" DEVANAGARI LETTER GHA
         U+096E: "८" DEVANAGARI DIGIT EIGHT -->
    <Key
        app:keySpec="&#x0917;"
        app:moreKeys="&#x0918;,%"
        app:keyHintLabel="8"
        app:additionalMoreKeys="&#x096E;,8" />
    <!-- U+0926: "द" DEVANAGARI LETTER DA
         U+0927: "ध" DEVANAGARI LETTER DHA
         U+096F: "९" DEVANAGARI DIGIT NINE -->
    <Key
        app:keySpec="&#x0926;"
        app:moreKeys="&#x0927;,%"
        app:keyHintLabel="9"
        app:additionalMoreKeys="&#x096F;,9" />
    <!-- U+091C: "ज" DEVANAGARI LETTER JA
         U+091D: "झ" DEVANAGARI LETTER JHA
         U+091C/U+094D/U+091E: "ज्ञ" DEVANAGARI LETTER JA/DEVANAGARI SIGN VIRAMA/DEVANAGARI LETTER NYA
         U+0966: "०" DEVANAGARI DIGIT ZERO -->
    <Key
        app:keySpec="&#x091C;"
        app:moreKeys="&#x091D;,&#x091C;&#x094D;&#x091E;,%"
        app:keyHintLabel="0"
        app:additionalMoreKeys="&#x0966;,0" />
    <!-- U+0921: "ड" DEVANAGARI LETTER DDA
         U+0922: "ढ" DEVANAGARI LETTER DDHA -->
    <Key
        app:keySpec="&#x0921;"
        app:moreKeys="&#x0922;" />
</merge>
