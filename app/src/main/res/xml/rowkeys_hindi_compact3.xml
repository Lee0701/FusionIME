<merge xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_candra_o" />
    <!-- U+0911: "ऑ" DEVANAGARI LETTER CANDRA O -->
    <Key
        app:keySpec="&#x0911;"
        app:keyStyle="moreKeysDevanagariVowelSignCandraO" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_sign_virama" />
    <Key app:keyStyle="baseKeyDevanagariSignVirama" />
    <!-- Because the font rendering system prior to API version 16 can't automatically
         render dotted circle for incomplete combining letter of some scripts, different
         set of Key definitions are needed based on the API version. -->
    <include app:keyboardLayout="@xml/keystyle_devanagari_sign_anusvara" />
    <Key app:keyStyle="baseKeyDevanagariSignAnusvara" />
    <!-- U+092E: "म" DEVANAGARI LETTER MA
         U+0950: "ॐ" DEVANAGARI OM -->
    <Key
        app:keySpec="&#x092E;"
        app:moreKeys="&#x0950;" />
    <!-- U+0928: "न" DEVANAGARI LETTER NA
         U+0923: "ण" DEVANAGARI LETTER NNA
         U+091E: "ञ" DEVANAGARI LETTER NYA
         U+0919: "ङ" DEVANAGARI LETTER NGA -->
    <Key
        app:keySpec="&#x0928;"
        app:moreKeys="&#x0923;,&#x091E;,&#x0919;" />
    <!-- U+0935: "व" DEVANAGARI LETTER VA -->
    <Key app:keySpec="&#x0935;" />
    <!-- U+0932: "ल" DEVANAGARI LETTER LA -->
    <Key app:keySpec="&#x0932;" />
    <!-- U+0938: "स" DEVANAGARI LETTER SA
         U+0936: "श" DEVANAGARI LETTER SHA
         U+0937: "ष" DEVANAGARI LETTER SSA
         U+0936/U+094D/U+0930: "श्र" DEVANAGARI LETTER SHA/DEVANAGARI SIGN VIRAMA/DEVANAGARI LETTER RA -->
    <Key
        app:keySpec="&#x0938;"
        app:moreKeys="&#x0936;,&#x0937;,&#x0936;&#x094D;&#x0930;" />
    <!-- U+092F: "य" DEVANAGARI LETTER YA -->
    <Key app:keySpec="&#x092F;" />
    <!-- U+0915/U+094D/U+0937: "क्ष" DEVANAGARI LETTER KA/DEVANAGARI SIGN VIRAMA/DEVANAGARI LETTER SSA -->
    <Key
        app:keySpec="&#x0915;&#x094D;&#x0937;"
        app:keyLabelFlags="followKeyLetterRatio" />
</merge>
